@model List<HotelManagement.ViewModels.Admin.ServiceListItemViewModel>

@{
    ViewData["Title"] = "Quản lý dịch vụ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title mb-0">Quản lý dịch vụ</h2>

    <a asp-controller="Admin"
       asp-action="CreateService"
       class="btn btn-primary">
        Thêm dịch vụ
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card card-dashboard">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Chưa có dịch vụ nào.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Tên dịch vụ</th>
                            <th>Danh mục</th>
                            <th>Đơn vị</th>
                            <th>Giá</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@item.Name</td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.Category) ? "-" : item.Category)
                                </td>

                                <td>
                                    @(string.IsNullOrWhiteSpace(item.Unit) ? "-" : item.Unit)
                                </td>

                                <td>@item.Price.ToString("N0") VNĐ</td>

                                <td>
                                    @if (item.Status == "Active")
                                    {
                                        <span class="badge bg-success">Đang dùng</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Ngưng dùng</span>
                                    }
                                </td>

                                <td class="text-end table-actions">
                                    <a asp-controller="Admin"
                                       asp-action="EditService"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Sửa
                                    </a>

                                    @if (item.Status == "Active")
                                    {
                                        <form asp-controller="Admin"
                                              asp-action="DeleteService"
                                              asp-route-id="@item.Id"
                                              method="post"
                                              class="d-inline"
                                              onsubmit="return confirm('Bạn có chắc muốn xóa dịch vụ này không?');">
                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-sm btn-danger">
                                                Xóa
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
