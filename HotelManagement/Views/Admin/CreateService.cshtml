@model HotelManagement.ViewModels.Admin.ServiceFormViewModel

@{
    ViewData["Title"] = "Thêm dịch vụ";
}

<h2 class="page-title">Thêm dịch vụ</h2>

<div class="card form-card">
    <div class="card-body">
        <form asp-controller="Admin" asp-action="CreateService" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Tên dịch vụ</label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Ăn sáng" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Category" class="form-label">Danh mục</label>
                    <input asp-for="Category" class="form-control" placeholder="Food, Laundry, Spa..." />
                    <span asp-validation-for="Category" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Unit" class="form-label">Đơn vị</label>
                    <input asp-for="Unit" class="form-control" placeholder="Suất, Kg, Lần..." />
                    <span asp-validation-for="Unit" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label">Giá</label>
                    <input asp-for="Price" class="form-control" type="number" step="1000" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Lưu
                </button>

                <a asp-controller="Admin"
                   asp-action="Services"
                   class="btn btn-secondary">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
