@model List<HotelManagement.ViewModels.Admin.RoomListItemViewModel>

@{
    ViewData["Title"] = "Quản lý phòng";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="page-title mb-0">Quản lý phòng</h2>

    <a asp-controller="Admin"
       asp-action="CreateRoom"
       class="btn btn-primary">
        Thêm phòng
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<div class="card card-dashboard">
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info mb-0">
                Chưa có phòng nào.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead>
                        <tr>
                            <th>Ảnh</th>
                            <th>Số phòng</th>
                            <th>Loại phòng</th>
                            <th>Tầng</th>
                            <th>Trạng thái</th>
                            <th>Ghi chú</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.MainImageUrl))
                                    {
                                        <img src="@item.MainImageUrl"
                                             alt="@item.RoomNumber"
                                             style="width: 80px; height: 55px; object-fit: cover; border-radius: 8px;" />
                                    }
                                    else
                                    {
                                        <div class="text-muted small">Chưa có ảnh</div>
                                    }

                                    <div class="text-muted small">
                                        @item.ImageCount ảnh
                                    </div>
                                </td>

                                <td class="fw-semibold">@item.RoomNumber</td>
                                <td>@item.RoomTypeName</td>
                                <td>@item.Floor</td>
                                <td>
                                    <span class="badge bg-secondary">@item.Status</span>
                                </td>
                                <td>@item.Note</td>
                                <td class="text-end table-actions">
                                    <a asp-controller="Admin"
                                       asp-action="RoomDetails"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-info">
                                        Chi tiết
                                    </a>

                                    <a asp-controller="Admin"
                                       asp-action="EditRoom"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        Sửa
                                    </a>

                                    <form asp-controller="Admin"
                                          asp-action="DeleteRoom"
                                          asp-route-id="@item.Id"
                                          method="post"
                                          class="d-inline"
                                          onsubmit="return confirm('Bạn có chắc muốn xóa phòng này không?');">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="btn btn-sm btn-danger">
                                            Xóa
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
