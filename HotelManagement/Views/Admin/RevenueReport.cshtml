@model HotelManagement.ViewModels.Admin.RevenueReportViewModel

@{
    ViewData["Title"] = "Báo cáo doanh thu";
}

<h2 class="mb-4">Báo cáo doanh thu</h2>

<form method="get" class="row mb-4">
    <div class="col-md-3">
        <label class="form-label">Từ ngày</label>
        <input type="date"
               name="fromDate"
               value="@Model.FromDate.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>

    <div class="col-md-3">
        <label class="form-label">Đến ngày</label>
        <input type="date"
               name="toDate"
               value="@Model.ToDate.ToString("yyyy-MM-dd")"
               class="form-control" />
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">
            Lọc
        </button>
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <a asp-controller="Admin"
           asp-action="RevenueReport"
           class="btn btn-secondary w-100">
            Tháng này
        </a>
    </div>
</form>

<div class="row">
    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Doanh thu khoảng lọc</h6>
                <h3>@Model.RangeRevenue.ToString("N0") đ</h3>
                <small>@Model.PaymentCount giao dịch</small>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Doanh thu hôm nay</h6>
                <h3>@Model.TodayRevenue.ToString("N0") đ</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Doanh thu tháng này</h6>
                <h3>@Model.MonthRevenue.ToString("N0") đ</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3 mb-3">
        <div class="card shadow-sm">
            <div class="card-body">
                <h6>Tổng doanh thu</h6>
                <h3>@Model.TotalRevenue.ToString("N0") đ</h3>
            </div>
        </div>
    </div>
</div>

<h4 class="mt-4">Doanh thu theo ngày</h4>

@if (!Model.RevenueByDays.Any())
{
    <div class="alert alert-info">
        Chưa có doanh thu trong khoảng thời gian này.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Ngày</th>
                <th>Số giao dịch</th>
                <th>Doanh thu</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RevenueByDays)
            {
                <tr>
                    <td>@item.Date.ToString("dd/MM/yyyy")</td>
                    <td>@item.PaymentCount</td>
                    <td>@item.Revenue.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>
}

<h4 class="mt-4">Doanh thu theo phương thức thanh toán</h4>

@if (!Model.RevenueByPaymentMethods.Any())
{
    <div class="alert alert-info">
        Chưa có dữ liệu thanh toán.
    </div>
}
else
{
    <table class="table table-bordered table-hover">
        <thead>
            <tr>
                <th>Phương thức</th>
                <th>Số giao dịch</th>
                <th>Doanh thu</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RevenueByPaymentMethods)
            {
                <tr>
                    <td>@item.PaymentMethod</td>
                    <td>@item.PaymentCount</td>
                    <td>@item.Revenue.ToString("N0") đ</td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="row mt-4">
    <div class="col-md-6">
        <h4>Thống kê booking</h4>

        <table class="table table-bordered">
            <tr>
                <th>Booking trong khoảng lọc</th>
                <td>@Model.BookingCount</td>
            </tr>
            <tr>
                <th>Pending</th>
                <td>@Model.PendingBookings</td>
            </tr>
            <tr>
                <th>Confirmed</th>
                <td>@Model.ConfirmedBookings</td>
            </tr>
            <tr>
                <th>CheckedIn</th>
                <td>@Model.CheckedInBookings</td>
            </tr>
            <tr>
                <th>CheckedOut</th>
                <td>@Model.CheckedOutBookings</td>
            </tr>
            <tr>
                <th>Cancelled</th>
                <td>@Model.CancelledBookings</td>
            </tr>
        </table>
    </div>

    <div class="col-md-6">
        <h4>Thống kê hóa đơn</h4>

        <table class="table table-bordered">
            <tr>
                <th>Tổng hóa đơn</th>
                <td>@Model.TotalInvoices</td>
            </tr>
            <tr>
                <th>Đã thanh toán</th>
                <td>@Model.PaidInvoices</td>
            </tr>
            <tr>
                <th>Chưa thanh toán</th>
                <td>@Model.UnpaidInvoices</td>
            </tr>
            <tr>
                <th>Thanh toán một phần</th>
                <td>@Model.PartiallyPaidInvoices</td>
            </tr>
        </table>
    </div>
</div>
