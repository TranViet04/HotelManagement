@model HotelManagement.ViewModels.Admin.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2 class="page-title">Admin Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Loại phòng</div>
                <div class="fs-3 fw-semibold">@Model.TotalRoomTypes</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Tổng số phòng</div>
                <div class="fs-3 fw-semibold">@Model.TotalRooms</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Phòng trống</div>
                <div class="fs-3 fw-semibold text-success">@Model.AvailableRooms</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Đang sử dụng</div>
                <div class="fs-3 fw-semibold text-primary">@Model.OccupiedRooms</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Bảo trì</div>
                <div class="fs-3 fw-semibold text-warning">@Model.MaintenanceRooms</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Dịch vụ</div>
                <div class="fs-3 fw-semibold">@Model.TotalServices</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Tổng booking</div>
                <div class="fs-3 fw-semibold">@Model.TotalBookings</div>
            </div>
        </div>
    </div>

    <div class="col-md-4 col-xl-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Booking hôm nay</div>
                <div class="fs-3 fw-semibold">@Model.TodayBookings</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Doanh thu hôm nay</div>
                <div class="fs-4 fw-semibold">@Model.TodayRevenue.ToString("N0") VNĐ</div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small">Doanh thu tháng này</div>
                <div class="fs-4 fw-semibold">@Model.MonthRevenue.ToString("N0") VNĐ</div>
            </div>
        </div>
    </div>
</div>
