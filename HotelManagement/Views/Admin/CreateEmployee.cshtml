@model HotelManagement.ViewModels.Admin.CreateEmployeeViewModel

@{
    ViewData["Title"] = "Thêm nhân viên lễ tân";
}

<h2 class="page-title">Thêm nhân viên lễ tân</h2>

<div class="card form-card">
    <div class="card-body">
        <form asp-controller="Admin" asp-action="CreateEmployee" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="FullName" class="form-label">Họ tên</label>
                <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email đăng nhập</label>
                <input asp-for="Email" class="form-control" placeholder="receptionist2@gmail.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PhoneNumber" class="form-label">Số điện thoại</label>
                <input asp-for="PhoneNumber" class="form-control" placeholder="0900000000" />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label">Mật khẩu</label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label">Nhập lại mật khẩu</label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="alert alert-info">
                Tài khoản được tạo ở đây sẽ có quyền <strong>Lễ tân</strong>. Admin không tạo tài khoản Admin từ màn hình này.
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Lưu
                </button>

                <a asp-controller="Admin"
                   asp-action="Employees"
                   class="btn btn-secondary">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
