@model HotelManagement.ViewModels.Admin.RoomTypeFormViewModel

@{
    ViewData["Title"] = "Thêm loại phòng";
}

<h2 class="page-title">Thêm loại phòng</h2>

<div class="card form-card">
    <div class="card-body">
        <form asp-controller="Admin" asp-action="CreateRoomType" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Tên loại phòng</label>
                <input asp-for="Name" class="form-control" placeholder="Ví dụ: Deluxe" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    <label asp-for="Price" class="form-label">Giá mỗi đêm</label>
                    <input asp-for="Price" class="form-control" type="number" step="1000" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="Capacity" class="form-label">Sức chứa</label>
                    <input asp-for="Capacity" class="form-control" type="number" />
                    <span asp-validation-for="Capacity" class="text-danger"></span>
                </div>

                <div class="col-md-4 mb-3">
                    <label asp-for="BedType" class="form-label">Loại giường</label>
                    <input asp-for="BedType" class="form-control" placeholder="1 giường đôi" />
                    <span asp-validation-for="BedType" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label for="images" class="form-label">Hình ảnh loại phòng</label>
                <input type="file"
                       id="images"
                       name="images"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp"
                       multiple />
                <div class="form-text">
                    Có thể chọn nhiều ảnh. Hỗ trợ JPG, PNG, WEBP, tối đa 5MB mỗi ảnh.
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    Lưu
                </button>

                <a asp-controller="Admin"
                   asp-action="RoomTypes"
                   class="btn btn-secondary">
                    Quay lại
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
