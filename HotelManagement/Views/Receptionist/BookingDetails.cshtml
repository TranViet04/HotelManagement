@model HotelManagement.ViewModels.Receptionist.ReceptionistBookingDetailViewModel

@{
    ViewData["Title"] = "Chi tiết booking";

    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Confirmed" => "bg-primary",
            "CheckedIn" => "bg-info text-dark",
            "CheckedOut" => "bg-success",
            "Cancelled" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }

    string GetStatusText(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "CheckedIn" => "Đã nhận phòng",
            "CheckedOut" => "Đã trả phòng",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    string FormatDateTime(DateTime? value)
    {
        return value.HasValue ? value.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa có";
    }
}

<section class="receptionist-booking-detail-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Chi tiết booking
            </div>

            <h1 class="fw-bold mb-3">
                @Model.BookingCode
            </h1>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="badge @GetStatusBadgeClass(Model.Status) receptionist-booking-status">
                    @GetStatusText(Model.Status)
                </span>

                <span class="text-muted">
                    Tạo lúc @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="Bookings"
               class="btn btn-outline-primary">
                Quay lại danh sách
            </a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin khách hàng</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Họ tên:</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div>
                        <span class="text-muted">Email:</span>
                        <strong>@(Model.CustomerEmail ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Số điện thoại:</span>
                        <strong>@(Model.CustomerPhoneNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">CCCD/CMND:</span>
                        <strong>@(Model.CustomerIdentityNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Địa chỉ:</span>
                        <strong>@(Model.CustomerAddress ?? "Chưa có")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin phòng</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Loại phòng:</span>
                        <strong>@Model.RoomTypeName</strong>
                    </div>

                    <div>
                        <span class="text-muted">Số phòng:</span>
                        <strong>@Model.RoomNumber</strong>
                    </div>

                    <div>
                        <span class="text-muted">Tầng:</span>
                        <strong>@(Model.Floor.HasValue ? Model.Floor.Value.ToString() : "Chưa cập nhật")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Giá mỗi đêm:</span>
                        <strong>@Model.PricePerNight.ToString("N0") VND</strong>
                    </div>

                    <div>
                        <span class="text-muted">Sức chứa:</span>
                        <strong>@Model.Capacity khách</strong>
                    </div>

                    <div>
                        <span class="text-muted">Loại giường:</span>
                        <strong>@(Model.BedType ?? "Đang cập nhật")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin lưu trú</h5>

                <div class="receptionist-booking-detail-grid mb-4">
                    <div>
                        <span>Ngày nhận phòng</span>
                        <strong>@Model.CheckInDate.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div>
                        <span>Ngày trả phòng</span>
                        <strong>@Model.CheckOutDate.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div>
                        <span>Số đêm</span>
                        <strong>@Model.Nights</strong>
                    </div>

                    <div>
                        <span>Số khách</span>
                        <strong>@Model.Adults người lớn, @Model.Children trẻ em</strong>
                    </div>
                </div>

                <h5 class="fw-bold mb-3">Tiến trình</h5>

                <div class="room-info-list mb-4">
                    <div>
                        <span class="text-muted">Tạo booking:</span>
                        <strong>@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Xác nhận:</span>
                        <strong>@FormatDateTime(Model.ConfirmedAt)</strong>
                    </div>

                    <div>
                        <span class="text-muted">Nhận phòng:</span>
                        <strong>@FormatDateTime(Model.CheckedInAt)</strong>
                    </div>

                    <div>
                        <span class="text-muted">Trả phòng:</span>
                        <strong>@FormatDateTime(Model.CheckedOutAt)</strong>
                    </div>

                    <div>
                        <span class="text-muted">Hủy:</span>
                        <strong>@FormatDateTime(Model.CancelledAt)</strong>
                    </div>
                </div>

                <h5 class="fw-bold mb-3">Yêu cầu đặc biệt</h5>

                @if (string.IsNullOrWhiteSpace(Model.SpecialRequest))
                {
                    <div class="alert alert-light border">
                        Khách hàng không nhập yêu cầu đặc biệt.
                    </div>
                }
                else
                {
                    <div class="alert alert-light border">
                        @Model.SpecialRequest
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(Model.CancelReason))
                {
                    <h5 class="fw-bold mb-3">Lý do hủy</h5>

                    <div class="alert alert-secondary">
                        @Model.CancelReason
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                    <div>
                        <h5 class="fw-bold mb-1">Hóa đơn</h5>

                        @if (Model.InvoiceId.HasValue)
                        {
                            <p class="text-muted mb-0">
                                Booking này đã có hóa đơn @Model.InvoiceCode - trạng thái @Model.InvoiceStatus.
                            </p>
                            @if (Model.InvoiceRemainingAmount > 0)
                            {
                                <p class="text-danger fw-bold mt-1 mb-0">
                                    <i class="bi bi-exclamation-triangle-fill"></i> Dư nợ chưa thanh toán: @Model.InvoiceRemainingAmount.ToString("N0") VND
                                </p>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-0">
                                Booking này chưa có hóa đơn.
                            </p>
                        }
                    </div>

                    <div class="d-flex gap-2">
                        @if (Model.InvoiceId.HasValue)
                        {
                            @if (Model.InvoiceRemainingAmount > 0)
                            {
                                <a asp-controller="Receptionist"
                                   asp-action="RecordPayment"
                                   asp-route-invoiceId="@Model.InvoiceId.Value"
                                   class="btn btn-warning fw-bold">
                                    Thanh toán nợ
                                </a>
                            }
                            <a asp-controller="Receptionist"
                               asp-action="InvoiceDetails"
                               asp-route-id="@Model.InvoiceId.Value"
                               class="btn btn-outline-primary">
                                Xem hóa đơn
                            </a>
                        }
                        else if (Model.CanCreateInvoice)
                        {
                            <form asp-controller="Receptionist"
                                  asp-action="CreateInvoice"
                                  asp-route-bookingId="@Model.BookingId"
                                  method="post"
                                  class="d-inline">
                                @Html.AntiForgeryToken()

                                <button type="submit" class="btn btn-primary">
                                    Tạo hóa đơn
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Chi phí</h5>

                <div class="booking-cost-row">
                    <span>Tiền phòng</span>
                    <strong>@Model.TotalRoomAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Tiền dịch vụ</span>
                    <strong>@Model.TotalServiceAmount.ToString("N0") VND</strong>
                </div>

                <hr />

                <div class="booking-cost-row booking-cost-total">
                    <span>Tổng cộng</span>
                    <strong>@Model.TotalAmount.ToString("N0") VND</strong>
                </div>

                @if (Model.InvoiceId.HasValue)
                {
                    <div class="booking-cost-row mt-2 text-success">
                        <span>Đã thanh toán</span>
                        <strong>@Model.InvoicePaidAmount.ToString("N0") VND</strong>
                    </div>
                    
                    @if (Model.InvoiceRemainingAmount > 0)
                    {
                        <div class="booking-cost-row mt-2 text-danger fw-bold">
                            <span>Dư nợ (phát sinh)</span>
                            <strong>@Model.InvoiceRemainingAmount.ToString("N0") VND</strong>
                        </div>
                    }
                }

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <a asp-controller="Receptionist"
                       asp-action="Bookings"
                       class="btn btn-outline-secondary">
                        Quay lại
                    </a>

                    @if (Model.CanConfirm)
                    {
                        <form asp-controller="Receptionist"
                              asp-action="ConfirmBooking"
                              asp-route-id="@Model.BookingId"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-primary">
                                Xác nhận booking
                            </button>
                        </form>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.ConfirmBlockReason">
                            Không thể xác nhận
                        </button>
                    }

                    @if (Model.CanCheckIn)
                    {
                        <form asp-controller="Receptionist"
                              asp-action="CheckInBooking"
                              asp-route-id="@Model.BookingId"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-success">
                                Check-in
                            </button>
                        </form>
                    }
                    else if (Model.Status == "Confirmed")
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.CheckInBlockReason">
                            Chưa thể check-in
                        </button>
                    }

                    @if (Model.CanAddService)
                    {
                        <a asp-controller="Receptionist"
                           asp-action="AddService"
                           asp-route-bookingId="@Model.BookingId"
                           class="btn btn-success">
                            Thêm dịch vụ
                        </a>
                    }
                    else if (Model.Status == "CheckedIn")
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.AddServiceBlockReason">
                            Không thể thêm dịch vụ
                        </button>
                    }

                    @if (Model.CanCheckOut)
                    {
                        <form asp-controller="Receptionist"
                              asp-action="CheckOutBooking"
                              asp-route-id="@Model.BookingId"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-danger">
                                Check-out
                            </button>
                        </form>
                    }
                    else if (Model.Status == "CheckedIn")
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.CheckOutBlockReason">
                            Không thể check-out
                        </button>
                    }

                    @if (Model.InvoiceId.HasValue)
                    {
                        @if (Model.InvoiceRemainingAmount > 0)
                        {
                            <a asp-controller="Receptionist"
                               asp-action="RecordPayment"
                               asp-route-invoiceId="@Model.InvoiceId.Value"
                               class="btn btn-warning fw-bold">
                                Thanh toán nợ
                            </a>
                        }
                        <a asp-controller="Receptionist"
                           asp-action="InvoiceDetails"
                           asp-route-id="@Model.InvoiceId.Value"
                           class="btn btn-primary">
                            Xem hóa đơn
                        </a>
                    }
                    else if (Model.CanCreateInvoice)
                    {
                        <form asp-controller="Receptionist"
                              asp-action="CreateInvoice"
                              asp-route-bookingId="@Model.BookingId"
                              method="post"
                              class="d-inline">
                            @Html.AntiForgeryToken()

                            <button type="submit" class="btn btn-primary">
                                Tạo hóa đơn
                            </button>
                        </form>
                    }
                    else if (Model.Status == "CheckedOut")
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.CreateInvoiceBlockReason">
                            Không thể tạo hóa đơn
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Dịch vụ phát sinh</h5>

                    @if (Model.CanAddService)
                    {
                        <a asp-controller="Receptionist"
                           asp-action="AddService"
                           asp-route-bookingId="@Model.BookingId"
                           class="btn btn-success btn-sm">
                            Thêm dịch vụ
                        </a>
                    }
                </div>

                @if (Model.Services == null || !Model.Services.Any())
                {
                    <div class="alert alert-info mb-0">
                        Booking này chưa có dịch vụ phát sinh.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 receptionist-service-items-table">
                            <thead>
                                <tr>
                                    <th>Dịch vụ</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.Services)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.ServiceName</div>
                                            <div class="text-muted small">
                                                @(item.Category ?? "Chưa phân loại")
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(item.Note))
                                            {
                                                <div class="text-muted small">
                                                    Ghi chú: @item.Note
                                                </div>
                                            }
                                        </td>
                                        <td>@item.Quantity @(item.Unit ?? "")</td>
                                        <td>@item.UnitPrice.ToString("N0") VND</td>
                                        <td><strong>@item.TotalPrice.ToString("N0") VND</strong></td>
                                        <td>@item.UsedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
