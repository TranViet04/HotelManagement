@model HotelManagement.ViewModels.Receptionist.ReceptionistBookingDetailViewModel

@{
    ViewData["Title"] = "Thanh toán tại quầy";
    var paymentMethod = ViewBag.PaymentMethod as string;
}

<section class="receptionist-walkin-payment-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Thanh toán Booking
            </div>
            <h1 class="fw-bold mb-3">Thanh toán & Xác nhận</h1>
            <p class="text-muted mb-0">Booking @Model.BookingCode - Khách hàng: @Model.CustomerName</p>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin hóa đơn</h5>
                <div class="booking-cost-row mb-2">
                    <span>Tổng tiền phòng:</span>
                    <strong>@Model.TotalAmount.ToString("N0") VND</strong>
                </div>
                <div class="booking-cost-row mb-4 booking-cost-total">
                    <span>Cần thanh toán:</span>
                    <strong class="text-primary fs-4">@Model.TotalAmount.ToString("N0") VND</strong>
                </div>
                <div class="alert alert-info">
                    Phương thức: <strong>@(paymentMethod == "Cash" ? "Tiền mặt" : "Chuyển khoản SePay")</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                
                @if (paymentMethod == "Cash")
                {
                    <h5 class="fw-bold mb-4">Thu tiền mặt</h5>
                    
                    <form asp-controller="Receptionist" asp-action="ConfirmWalkInCashPayment" method="post" id="cashPaymentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="bookingId" value="@Model.BookingId" />
                        
                        <div class="mb-4 text-start" style="max-width: 400px; margin: 0 auto;">
                            <label class="form-label">Số tiền khách đưa (VND)</label>
                            <input type="number" id="amountReceived" class="form-control form-control-lg" required min="@Model.TotalAmount" />
                            <div class="form-text">Nhập số tiền nhận từ khách để tính tiền thối.</div>
                        </div>

                        <div class="mb-4 text-start" style="max-width: 400px; margin: 0 auto;">
                            <label class="form-label">Tiền thối lại (VND)</label>
                            <input type="text" id="changeAmount" class="form-control form-control-lg bg-light text-danger fw-bold" readonly value="0" />
                        </div>

                        <button type="submit" class="btn btn-success btn-lg px-5">Xác nhận thu tiền & In hóa đơn</button>
                    </form>

                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            const totalAmount = @Model.TotalAmount;
                            const amountReceivedInput = document.getElementById("amountReceived");
                            const changeAmountInput = document.getElementById("changeAmount");

                            amountReceivedInput.addEventListener("input", function() {
                                let received = parseFloat(amountReceivedInput.value);
                                if (isNaN(received)) received = 0;
                                let change = received - totalAmount;
                                if (change < 0) change = 0;
                                changeAmountInput.value = change.toLocaleString("vi-VN");
                            });
                        });
                    </script>
                }
                else
                {
                    <h5 class="fw-bold mb-4">Thanh toán chuyển khoản</h5>
                    <p class="text-muted">Nhấn nút bên dưới để mở mã QR sang tab mới cho khách hàng quét.</p>
                    
                    <a href="@Url.Action("WalkInPaymentQrTab", "Receptionist", new { bookingId = Model.BookingId })" target="_blank" class="btn btn-primary btn-lg mb-4 px-5">
                        <i class="bi bi-qr-code-scan me-2"></i> Mở mã QR cho khách quét
                    </a>

                    <div id="payment-status-container" class="mt-3">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="mt-2 text-muted">Đang chờ khách thanh toán...</p>
                    </div>

                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            const checkPaymentStatus = async () => {
                                try {
                                    const response = await fetch('/Payment/Status?bookingCode=@Model.BookingCode');
                                    if (response.ok) {
                                        const result = await response.json();
                                        if (result.status === 'Paid') {
                                            document.getElementById('payment-status-container').innerHTML = `
                                                <div class="alert alert-success">
                                                    <i class="bi bi-check-circle-fill me-2"></i> Khách đã thanh toán thành công!
                                                </div>
                                                <a href="/Receptionist/PrintInvoice?invoiceId=@Model.InvoiceId" class="btn btn-success">In hóa đơn</a>
                                            `;
                                            return; // Stop polling
                                        }
                                    }
                                } catch (error) {
                                    console.error('Error checking payment status:', error);
                                }
                                setTimeout(checkPaymentStatus, 3000); // Check again after 3 seconds
                            };

                            // Start polling
                            setTimeout(checkPaymentStatus, 3000);
                        });
                    </script>
                }
            </div>
        </div>
    </div>
</div>
