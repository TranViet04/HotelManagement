@model HotelManagement.ViewModels.Receptionist.RecordPaymentViewModel

@{
    ViewData["Title"] = "Ghi nhận thanh toán";

    string GetInvoiceStatusText(string status)
    {
        return status switch
        {
            "Unpaid" => "Chưa thanh toán",
            "PartiallyPaid" => "Thanh toán một phần",
            "Paid" => "Đã thanh toán",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    string GetPaymentMethodText(string paymentMethod)
    {
        return paymentMethod switch
        {
            "Cash" => "Tiền mặt",
            "BankTransfer" => "Chuyển khoản",
            _ => paymentMethod
        };
    }
}

<section class="receptionist-record-payment-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-success fw-semibold mb-2">
                Ghi nhận thanh toán
            </div>

            <h1 class="fw-bold mb-3">
                @Model.InvoiceCode
            </h1>

            <p class="text-muted mb-0">
                Xác nhận khoản thu thủ công cho hóa đơn của booking @Model.BookingCode.
            </p>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="InvoiceDetails"
               asp-route-id="@Model.InvoiceId"
               class="btn btn-outline-primary">
                Chi tiết hóa đơn
            </a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin hóa đơn</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Mã hóa đơn:</span>
                        <strong>@Model.InvoiceCode</strong>
                    </div>

                    <div>
                        <span class="text-muted">Mã booking:</span>
                        <a asp-controller="Receptionist"
                           asp-action="BookingDetails"
                           asp-route-id="@Model.BookingId"
                           class="fw-semibold text-decoration-none">
                            @Model.BookingCode
                        </a>
                    </div>

                    <div>
                        <span class="text-muted">Khách hàng:</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div>
                        <span class="text-muted">SĐT:</span>
                        <strong>@(Model.CustomerPhoneNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Phòng:</span>
                        <strong>@Model.RoomTypeName - @Model.RoomNumber</strong>
                    </div>

                    <div>
                        <span class="text-muted">Trạng thái:</span>
                        <strong>@GetInvoiceStatusText(Model.InvoiceStatus)</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Số tiền</h5>

                <div class="booking-cost-row">
                    <span>Tổng hóa đơn</span>
                    <strong>@Model.TotalAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Đã thanh toán</span>
                    <strong>@Model.PaidAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row booking-cost-total">
                    <span>Còn lại</span>
                    <strong>@Model.RemainingAmount.ToString("N0") VND</strong>
                </div>
            </div>
        </div>
        
        @if (Model.UnpaidServices != null && Model.UnpaidServices.Any())
        {
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-3 text-warning"><i class="bi bi-cart-plus"></i> Dịch vụ phát sinh</h5>
                    <p class="small text-muted mb-3">Các dịch vụ khách đã sử dụng tạo ra khoản dư nợ này:</p>
                    
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Dịch vụ</th>
                                    <th>SL</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.UnpaidServices)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.ServiceName</div>
                                            <div class="text-muted" style="font-size: 0.75rem;">@item.UsedAt.ToString("dd/MM HH:mm")</div>
                                        </td>
                                        <td>@item.Quantity</td>
                                        <td class="text-end"><strong>@item.TotalPrice.ToString("N0")</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                @if (!Model.CanRecordPayment)
                {
                    <div class="alert alert-warning mb-0">
                        @Model.RecordPaymentBlockReason
                    </div>
                }
                else
                {
                    <h5 class="fw-bold mb-3">Thông tin thanh toán</h5>

                    <form asp-controller="Receptionist" asp-action="RecordPayment" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="InvoiceId" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Phương thức</label>
                            <select asp-for="PaymentMethod"
                                    asp-items="Model.PaymentMethodOptions"
                                    class="form-select" id="paymentMethodSelect"></select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>

                        <div class="mb-3" id="amountGroup">
                            <label asp-for="Amount" class="form-label">Số tiền thu</label>
                            <input asp-for="Amount"
                                   type="number"
                                   min="1"
                                   step="1000"
                                   value="@Model.Amount.ToString("0")"
                                   class="form-control" id="amountInput" />
                            <span asp-validation-for="Amount" class="text-danger"></span>

                            <div class="form-text">
                                Không được vượt quá <span id="maxAmountText">@Model.RemainingAmount.ToString("N0")</span> VND.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label">Ghi chú</label>
                            <textarea asp-for="Note"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Ví dụ: khách thanh toán tiền mặt tại quầy..."></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                        <div id="cashDetailsGroup" style="display: none;" class="mb-3 p-3 bg-light rounded border border-success">
                            <h6 class="fw-bold text-success mb-3"><i class="bi bi-cash-stack"></i> Thu tiền mặt</h6>
                            <div class="mb-3">
                                <label class="form-label">Số tiền khách đưa (VND)</label>
                                <input type="number" id="amountReceived" class="form-control form-control-lg" />
                                <div class="form-text">Nhập số tiền nhận từ khách để tính tiền thối.</div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Tiền thối lại (VND)</label>
                                <input type="text" id="changeAmount" class="form-control form-control-lg text-danger fw-bold" readonly value="0" />
                            </div>
                        </div>

                        <div id="sepayDetailsGroup" style="display: none;" class="mb-3 p-3 bg-light rounded border border-primary text-center">
                            <h6 class="fw-bold text-primary mb-3"><i class="bi bi-qr-code"></i> Thu chuyển khoản (SePay)</h6>
                            <p class="text-muted small">Mở mã QR sang Tab mới cho khách hàng quét.</p>
                            <button type="button" id="btnOpenQr" class="btn btn-primary">
                                <i class="bi bi-qr-code-scan me-1"></i> Mở mã QR
                            </button>
                            
                            <div id="payment-status-container" class="mt-3" style="display: none;">
                                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                <span class="ms-2 text-muted">Đang chờ khách thanh toán...</span>
                            </div>
                        </div>

                        <div class="d-flex flex-wrap gap-2 mt-4" id="submitButtonGroup">
                            <button type="submit" class="btn btn-success" id="btnSubmitPayment">
                                Xác nhận thu tiền & In hóa đơn
                            </button>

                            <a asp-controller="Receptionist"
                               asp-action="InvoiceDetails"
                               asp-route-id="@Model.InvoiceId"
                               class="btn btn-outline-secondary">
                                Hủy
                            </a>
                        </div>
                    </form>
                    
                    <script>
                        document.addEventListener("DOMContentLoaded", function() {
                            const paymentMethodSelect = document.getElementById("paymentMethodSelect");
                            const amountInput = document.getElementById("amountInput");
                            const cashDetailsGroup = document.getElementById("cashDetailsGroup");
                            const sepayDetailsGroup = document.getElementById("sepayDetailsGroup");
                            const amountReceived = document.getElementById("amountReceived");
                            const changeAmount = document.getElementById("changeAmount");
                            const btnOpenQr = document.getElementById("btnOpenQr");
                            const paymentStatusContainer = document.getElementById("payment-status-container");
                            const btnSubmitPayment = document.getElementById("btnSubmitPayment");

                            const maxAmount = @Model.RemainingAmount;
                            let pollingInterval = null;

                            function updateUI() {
                                const method = paymentMethodSelect.value;
                                
                                if (method === "Cash") {
                                    cashDetailsGroup.style.display = "block";
                                    sepayDetailsGroup.style.display = "none";
                                    btnSubmitPayment.style.display = "inline-block";
                                    calculateChange();
                                } else if (method === "BankTransfer" || method === "SePay") {
                                    cashDetailsGroup.style.display = "none";
                                    sepayDetailsGroup.style.display = "block";
                                    btnSubmitPayment.style.display = "none"; // Hide submit, wait for SePay webhook
                                } else {
                                    cashDetailsGroup.style.display = "none";
                                    sepayDetailsGroup.style.display = "none";
                                    btnSubmitPayment.style.display = "inline-block";
                                }
                            }

                            function calculateChange() {
                                let amountToPay = parseFloat(amountInput.value);
                                if (isNaN(amountToPay)) amountToPay = 0;
                                
                                let received = parseFloat(amountReceived.value);
                                if (isNaN(received)) received = 0;
                                
                                let change = received - amountToPay;
                                if (change < 0) change = 0;
                                
                                changeAmount.value = change.toLocaleString("vi-VN");
                            }

                            paymentMethodSelect.addEventListener("change", updateUI);
                            amountInput.addEventListener("input", calculateChange);
                            amountReceived.addEventListener("input", calculateChange);

                            btnOpenQr.addEventListener("click", function() {
                                let amountToPay = parseFloat(amountInput.value);
                                if (isNaN(amountToPay) || amountToPay <= 0) {
                                    alert("Vui lòng nhập số tiền thu hợp lệ.");
                                    return;
                                }
                                
                                const url = `/Receptionist/InvoicePaymentQrTab?invoiceId=@Model.InvoiceId&amount=${amountToPay}`;
                                window.open(url, '_blank');
                                
                                paymentStatusContainer.style.display = "block";
                                startPolling();
                            });

                            function startPolling() {
                                if (pollingInterval) clearInterval(pollingInterval);
                                
                                pollingInterval = setInterval(async () => {
                                    try {
                                        const response = await fetch('/Payment/Status?invoiceCode=@Model.InvoiceCode');
                                        if (response.ok) {
                                            const result = await response.json();
                                            // If invoice is fully paid or remainingAmount is 0
                                            if (result.status === 'Paid' || result.remainingAmount === 0) {
                                                clearInterval(pollingInterval);
                                                paymentStatusContainer.innerHTML = `
                                                    <div class="alert alert-success mt-2 mb-0">
                                                        <i class="bi bi-check-circle-fill me-2"></i> Khách đã thanh toán thành công!
                                                    </div>
                                                `;
                                                // After success, we can redirect to PrintInvoice
                                                setTimeout(() => {
                                                    window.location.href = `/Receptionist/PrintInvoice?invoiceId=@Model.InvoiceId`;
                                                }, 2000);
                                            }
                                        }
                                    } catch (error) {
                                        console.error('Error checking status:', error);
                                    }
                                }, 3000);
                            }

                            // Initialize UI
                            updateUI();
                        });
                    </script>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Lịch sử thanh toán</h5>

                @if (Model.ExistingPayments == null || !Model.ExistingPayments.Any())
                {
                    <div class="alert alert-info mb-0">
                        Hóa đơn này chưa có giao dịch thanh toán.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 receptionist-payment-lines-table">
                            <thead>
                                <tr>
                                    <th>Mã</th>
                                    <th>Phương thức</th>
                                    <th>Số tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var payment in Model.ExistingPayments)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@payment.PaymentCode</div>

                                            @if (!string.IsNullOrWhiteSpace(payment.Note))
                                            {
                                                <div class="text-muted small">
                                                    @payment.Note
                                                </div>
                                            }
                                        </td>

                                        <td>@GetPaymentMethodText(payment.PaymentMethod)</td>

                                        <td>
                                            <strong>@payment.Amount.ToString("N0") VND</strong>
                                        </td>

                                        <td>@payment.Status</td>

                                        <td>@(payment.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
