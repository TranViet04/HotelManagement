@model HotelManagement.ViewModels.Receptionist.RecordPaymentViewModel

@{
    ViewData["Title"] = "Ghi nhận thanh toán";

    string GetInvoiceStatusText(string status)
    {
        return status switch
        {
            "Unpaid" => "Chưa thanh toán",
            "PartiallyPaid" => "Thanh toán một phần",
            "Paid" => "Đã thanh toán",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }

    string GetPaymentMethodText(string paymentMethod)
    {
        return paymentMethod switch
        {
            "Cash" => "Tiền mặt",
            "BankTransfer" => "Chuyển khoản",
            _ => paymentMethod
        };
    }
}

<section class="receptionist-record-payment-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-success fw-semibold mb-2">
                Ghi nhận thanh toán
            </div>

            <h1 class="fw-bold mb-3">
                @Model.InvoiceCode
            </h1>

            <p class="text-muted mb-0">
                Xác nhận khoản thu thủ công cho hóa đơn của booking @Model.BookingCode.
            </p>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="InvoiceDetails"
               asp-route-id="@Model.InvoiceId"
               class="btn btn-outline-primary">
                Chi tiết hóa đơn
            </a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin hóa đơn</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Mã hóa đơn:</span>
                        <strong>@Model.InvoiceCode</strong>
                    </div>

                    <div>
                        <span class="text-muted">Mã booking:</span>
                        <a asp-controller="Receptionist"
                           asp-action="BookingDetails"
                           asp-route-id="@Model.BookingId"
                           class="fw-semibold text-decoration-none">
                            @Model.BookingCode
                        </a>
                    </div>

                    <div>
                        <span class="text-muted">Khách hàng:</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div>
                        <span class="text-muted">SĐT:</span>
                        <strong>@(Model.CustomerPhoneNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Phòng:</span>
                        <strong>@Model.RoomTypeName - @Model.RoomNumber</strong>
                    </div>

                    <div>
                        <span class="text-muted">Trạng thái:</span>
                        <strong>@GetInvoiceStatusText(Model.InvoiceStatus)</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Số tiền</h5>

                <div class="booking-cost-row">
                    <span>Tổng hóa đơn</span>
                    <strong>@Model.TotalAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Đã thanh toán</span>
                    <strong>@Model.PaidAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row booking-cost-total">
                    <span>Còn lại</span>
                    <strong>@Model.RemainingAmount.ToString("N0") VND</strong>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                @if (!Model.CanRecordPayment)
                {
                    <div class="alert alert-warning mb-0">
                        @Model.RecordPaymentBlockReason
                    </div>
                }
                else
                {
                    <h5 class="fw-bold mb-3">Thông tin thanh toán</h5>

                    <form asp-controller="Receptionist" asp-action="RecordPayment" method="post">
                        @Html.AntiForgeryToken()

                        <input asp-for="InvoiceId" type="hidden" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="PaymentMethod" class="form-label">Phương thức</label>
                            <select asp-for="PaymentMethod"
                                    asp-items="Model.PaymentMethodOptions"
                                    class="form-select"></select>
                            <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Amount" class="form-label">Số tiền</label>
                            <input asp-for="Amount"
                                   type="number"
                                   min="1"
                                   step="1000"
                                   class="form-control" />
                            <span asp-validation-for="Amount" class="text-danger"></span>

                            <div class="form-text">
                                Không được vượt quá @Model.RemainingAmount.ToString("N0") VND.
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Note" class="form-label">Ghi chú</label>
                            <textarea asp-for="Note"
                                      class="form-control"
                                      rows="3"
                                      placeholder="Ví dụ: khách thanh toán tiền mặt tại quầy..."></textarea>
                            <span asp-validation-for="Note" class="text-danger"></span>
                        </div>

                        <div class="d-flex flex-wrap gap-2">
                            <button type="submit" class="btn btn-success">
                                Ghi nhận thanh toán
                            </button>

                            <a asp-controller="Receptionist"
                               asp-action="InvoiceDetails"
                               asp-route-id="@Model.InvoiceId"
                               class="btn btn-outline-secondary">
                                Hủy
                            </a>
                        </div>
                    </form>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Lịch sử thanh toán</h5>

                @if (Model.ExistingPayments == null || !Model.ExistingPayments.Any())
                {
                    <div class="alert alert-info mb-0">
                        Hóa đơn này chưa có giao dịch thanh toán.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 receptionist-payment-lines-table">
                            <thead>
                                <tr>
                                    <th>Mã</th>
                                    <th>Phương thức</th>
                                    <th>Số tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var payment in Model.ExistingPayments)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@payment.PaymentCode</div>

                                            @if (!string.IsNullOrWhiteSpace(payment.Note))
                                            {
                                                <div class="text-muted small">
                                                    @payment.Note
                                                </div>
                                            }
                                        </td>

                                        <td>@GetPaymentMethodText(payment.PaymentMethod)</td>

                                        <td>
                                            <strong>@payment.Amount.ToString("N0") VND</strong>
                                        </td>

                                        <td>@payment.Status</td>

                                        <td>@payment.PaidAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
