@model HotelManagement.ViewModels.Receptionist.ReceptionistBookingListViewModel

@{
    ViewData["Title"] = "Quản lý đặt phòng";

    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Confirmed" => "bg-primary",
            "CheckedIn" => "bg-info text-dark",
            "CheckedOut" => "bg-success",
            "Cancelled" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }

    string GetStatusText(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "CheckedIn" => "Đã nhận phòng",
            "CheckedOut" => "Đã trả phòng",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }
}

<section class="receptionist-bookings-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Quản lý đặt phòng
            </div>

            <h1 class="fw-bold mb-3">
                Danh sách booking
            </h1>

            <p class="text-muted mb-0">
                Tìm kiếm, lọc và theo dõi toàn bộ đặt phòng của khách hàng.
            </p>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="CreateWalkInBooking"
               class="btn btn-primary">
                Tạo booking trực tiếp
            </a>
        </div>
    </div>
</section>

<section class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
        <form asp-controller="Receptionist" asp-action="Bookings" method="get" class="row g-3">
            <div class="col-lg-4">
                <label class="form-label">Từ khóa</label>
                <input type="text"
                       name="keyword"
                       class="form-control"
                       value="@Model.Keyword"
                       placeholder="Mã booking, tên khách, email, SĐT, số phòng" />
            </div>

            <div class="col-lg-2">
                <label class="form-label">Trạng thái</label>
                <select name="status" class="form-select" asp-items="Model.StatusOptions"></select>
            </div>

            <div class="col-lg-2">
                <label class="form-label">Nhận phòng từ</label>
                <input type="date"
                       name="checkInFrom"
                       class="form-control"
                       value="@(Model.CheckInFrom?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="col-lg-2">
                <label class="form-label">Nhận phòng đến</label>
                <input type="date"
                       name="checkInTo"
                       class="form-control"
                       value="@(Model.CheckInTo?.ToString("yyyy-MM-dd"))" />
            </div>

            <div class="col-lg-2 d-flex align-items-end">
                <div class="d-grid gap-2 w-100">
                    <button type="submit" class="btn btn-primary">
                        Lọc
                    </button>

                    <a asp-controller="Receptionist"
                       asp-action="Bookings"
                       class="btn btn-outline-secondary">
                        Xóa lọc
                    </a>
                </div>
            </div>
        </form>
    </div>
</section>

<section class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model.Bookings == null || !Model.Bookings.Any())
        {
            <div class="p-4">
                <div class="alert alert-info mb-0">
                    Không tìm thấy booking phù hợp.
                </div>
            </div>
        }
        else
        {
            <div class="p-4 border-bottom">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1">
                            Kết quả
                        </h5>

                        <p class="text-muted mb-0">
                            Tìm thấy @Model.Bookings.Count booking.
                        </p>
                    </div>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 receptionist-bookings-table">
                    <thead class="table-light">
                        <tr>
                            <th>Mã booking</th>
                            <th>Khách hàng</th>
                            <th>Phòng</th>
                            <th>Thời gian ở</th>
                            <th>Số khách</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th>Ngày tạo</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var booking in Model.Bookings)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@booking.BookingCode</div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@booking.CustomerName</div>

                                    <div class="text-muted small">
                                        @(booking.CustomerPhoneNumber ?? "Chưa có SĐT")
                                    </div>

                                    <div class="text-muted small">
                                        @(booking.CustomerEmail ?? "Chưa có email")
                                    </div>
                                </td>

                                <td>
                                    <div>@booking.RoomTypeName</div>
                                    <div class="text-muted small">
                                        Phòng @booking.RoomNumber
                                    </div>
                                </td>

                                <td>
                                    <div>
                                        @booking.CheckInDate.ToString("dd/MM/yyyy")
                                        -
                                        @booking.CheckOutDate.ToString("dd/MM/yyyy")
                                    </div>

                                    <div class="text-muted small">
                                        @booking.Nights đêm
                                    </div>
                                </td>

                                <td>
                                    <div>@booking.Adults người lớn</div>

                                    <div class="text-muted small">
                                        @booking.Children trẻ em
                                    </div>
                                </td>

                                <td>
                                    <strong class="text-primary">
                                        @booking.TotalAmount.ToString("N0") VND
                                    </strong>
                                </td>

                                <td>
                                    <span class="badge @GetStatusBadgeClass(booking.Status)">
                                        @GetStatusText(booking.Status)
                                    </span>
                                </td>

                                <td>
                                    <div>@booking.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">
                                        @booking.CreatedAt.ToString("HH:mm")
                                    </div>
                                </td>

                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-controller="Receptionist"
                                           asp-action="BookingDetails"
                                           asp-route-id="@booking.BookingId"
                                           class="btn btn-outline-primary btn-sm">
                                            Xem
                                        </a>

                                        @if (booking.Status == "Pending")
                                        {
                                            <a asp-controller="Receptionist"
                                               asp-action="BookingDetails"
                                               asp-route-id="@booking.BookingId"
                                               class="btn btn-primary btn-sm">
                                                Xác nhận
                                            </a>
                                        }

                                        @if (booking.Status == "Confirmed" && booking.CheckInDate.Date <= DateTime.Today && booking.CheckOutDate.Date > DateTime.Today)
                                        {
                                            <a asp-controller="Receptionist"
                                               asp-action="BookingDetails"
                                               asp-route-id="@booking.BookingId"
                                               class="btn btn-success btn-sm">
                                                Check-in
                                            </a>
                                        }

                                        @if (booking.Status == "CheckedIn")
                                        {
                                            <a asp-controller="Receptionist"
                                               asp-action="AddService"
                                               asp-route-bookingId="@booking.BookingId"
                                               class="btn btn-success btn-sm">
                                                Dịch vụ
                                            </a>

                                            <a asp-controller="Receptionist"
                                               asp-action="BookingDetails"
                                               asp-route-id="@booking.BookingId"
                                               class="btn btn-danger btn-sm">
                                                Check-out
                                            </a>
                                        }

                                        @if (booking.Status == "CheckedOut")
                                        {
                                            <a asp-controller="Receptionist"
                                               asp-action="BookingDetails"
                                               asp-route-id="@booking.BookingId"
                                               class="btn btn-primary btn-sm">
                                                Hóa đơn
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
