@model List<HotelManagement.ViewModels.Receptionist.ReceptionistBookingListItemViewModel>

@{
    ViewData["Title"] = "Check-in hôm nay";

    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Confirmed" => "bg-primary",
            "CheckedIn" => "bg-info text-dark",
            "CheckedOut" => "bg-success",
            "Cancelled" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }

    string GetStatusText(string status)
    {
        return status switch
        {
            "Pending" => "Chờ xác nhận",
            "Confirmed" => "Đã xác nhận",
            "CheckedIn" => "Đã nhận phòng",
            "CheckedOut" => "Đã trả phòng",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }
}

<section class="receptionist-checkin-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Check-in hôm nay
            </div>

            <h1 class="fw-bold mb-3">
                Danh sách khách nhận phòng hôm nay
            </h1>

            <p class="text-muted mb-0">
                Chỉ hiển thị các booking đã xác nhận và có ngày nhận phòng là hôm nay.
            </p>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="Bookings"
               class="btn btn-outline-primary">
                Xem toàn bộ booking
            </a>
        </div>
    </div>
</section>

<section class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4">
                <div class="alert alert-info mb-0">
                    Hôm nay không có booking nào cần check-in.
                </div>
            </div>
        }
        else
        {
            <div class="p-4 border-bottom">
                <h5 class="fw-bold mb-1">Danh sách check-in</h5>
                <p class="text-muted mb-0">
                    Có @Model.Count booking cần check-in hôm nay.
                </p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 receptionist-checkin-table">
                    <thead class="table-light">
                        <tr>
                            <th>Mã booking</th>
                            <th>Khách hàng</th>
                            <th>Phòng</th>
                            <th>Thời gian ở</th>
                            <th>Số khách</th>
                            <th>Tổng tiền</th>
                            <th>Trạng thái</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var booking in Model)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@booking.BookingCode</div>
                                </td>

                                <td>
                                    <div class="fw-semibold">@booking.CustomerName</div>
                                    <div class="text-muted small">
                                        @(booking.CustomerPhoneNumber ?? "Chưa có SĐT")
                                    </div>
                                    <div class="text-muted small">
                                        @(booking.CustomerEmail ?? "Chưa có email")
                                    </div>
                                </td>

                                <td>
                                    <div>@booking.RoomTypeName</div>
                                    <div class="text-muted small">
                                        Phòng @booking.RoomNumber
                                    </div>
                                </td>

                                <td>
                                    <div>
                                        @booking.CheckInDate.ToString("dd/MM/yyyy")
                                        -
                                        @booking.CheckOutDate.ToString("dd/MM/yyyy")
                                    </div>
                                    <div class="text-muted small">
                                        @booking.Nights đêm
                                    </div>
                                </td>

                                <td>
                                    <div>@booking.Adults người lớn</div>
                                    <div class="text-muted small">@booking.Children trẻ em</div>
                                </td>

                                <td>
                                    <strong class="text-primary">
                                        @booking.TotalAmount.ToString("N0") VND
                                    </strong>
                                </td>

                                <td>
                                    <div class="d-flex flex-column gap-1 align-items-start">
                                        <span class="badge @GetStatusBadgeClass(booking.Status)">
                                            @GetStatusText(booking.Status)
                                        </span>
                                        @if (booking.InvoiceStatus == "Paid")
                                        {
                                            <span class="badge bg-success">Đã thanh toán</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Chưa thanh toán</span>
                                        }
                                    </div>
                                </td>

                                <td class="text-end">
                                    <div class="d-inline-flex gap-2">
                                        <a asp-controller="Receptionist"
                                           asp-action="BookingDetails"
                                           asp-route-id="@booking.BookingId"
                                           class="btn btn-outline-primary btn-sm">
                                            Xem
                                        </a>

                                        <form asp-controller="Receptionist"
                                              asp-action="CheckInBooking"
                                              asp-route-id="@booking.BookingId"
                                              method="post"
                                              class="d-inline">
                                            @Html.AntiForgeryToken()

                                            <button type="submit" class="btn btn-success btn-sm">
                                                Check-in
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
