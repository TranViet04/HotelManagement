@model HotelManagement.ViewModels.Receptionist.ReceptionistInvoiceDetailViewModel

@{
    ViewData["Title"] = "Chi tiết hóa đơn";

    string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Unpaid" => "bg-warning text-dark",
            "PartiallyPaid" => "bg-info text-dark",
            "Paid" => "bg-success",
            "Cancelled" => "bg-secondary",
            _ => "bg-light text-dark"
        };
    }

    string GetStatusText(string status)
    {
        return status switch
        {
            "Unpaid" => "Chưa thanh toán",
            "PartiallyPaid" => "Thanh toán một phần",
            "Paid" => "Đã thanh toán",
            "Cancelled" => "Đã hủy",
            _ => status
        };
    }
}

<section class="receptionist-invoice-detail-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Chi tiết hóa đơn
            </div>

            <h1 class="fw-bold mb-3">
                @Model.InvoiceCode
            </h1>

            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="badge @GetStatusBadgeClass(Model.Status) receptionist-invoice-status">
                    @GetStatusText(Model.Status)
                </span>

                <span class="text-muted">
                    Lập lúc @Model.IssuedAt.ToString("dd/MM/yyyy HH:mm")
                </span>
            </div>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Receptionist"
               asp-action="Invoices"
               class="btn btn-outline-primary">
                Quay lại danh sách
            </a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin hóa đơn</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Mã hóa đơn:</span>
                        <strong>@Model.InvoiceCode</strong>
                    </div>

                    <div>
                        <span class="text-muted">Trạng thái:</span>
                        <strong>@GetStatusText(Model.Status)</strong>
                    </div>

                    <div>
                        <span class="text-muted">Người lập:</span>
                        <strong>@(Model.IssuedByName ?? "Không xác định")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Ngày lập:</span>
                        <strong>@Model.IssuedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Ghi chú:</span>
                        <strong>@(Model.Note ?? "Không có")</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin booking</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Mã booking:</span>
                        <a asp-controller="Receptionist"
                           asp-action="BookingDetails"
                           asp-route-id="@Model.BookingId"
                           class="fw-semibold text-decoration-none">
                            @Model.BookingCode
                        </a>
                    </div>

                    <div>
                        <span class="text-muted">Phòng:</span>
                        <strong>@Model.RoomTypeName - @Model.RoomNumber</strong>
                    </div>

                    <div>
                        <span class="text-muted">Ngày ở:</span>
                        <strong>@Model.CheckInDate.ToString("dd/MM/yyyy") - @Model.CheckOutDate.ToString("dd/MM/yyyy")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Số đêm:</span>
                        <strong>@Model.Nights</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thông tin khách hàng</h5>

                <div class="room-info-list">
                    <div>
                        <span class="text-muted">Họ tên:</span>
                        <strong>@Model.CustomerName</strong>
                    </div>

                    <div>
                        <span class="text-muted">Email:</span>
                        <strong>@(Model.CustomerEmail ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">SĐT:</span>
                        <strong>@(Model.CustomerPhoneNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">CCCD/CMND:</span>
                        <strong>@(Model.CustomerIdentityNumber ?? "Chưa có")</strong>
                    </div>

                    <div>
                        <span class="text-muted">Địa chỉ:</span>
                        <strong>@(Model.CustomerAddress ?? "Chưa có")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Chi tiết tiền</h5>

                <div class="booking-cost-row">
                    <span>Tiền phòng</span>
                    <strong>@Model.RoomAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Tiền dịch vụ</span>
                    <strong>@Model.ServiceAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Giảm giá</span>
                    <strong>@Model.DiscountAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Thuế</span>
                    <strong>@Model.TaxAmount.ToString("N0") VND</strong>
                </div>

                <hr />

                <div class="booking-cost-row booking-cost-total">
                    <span>Tổng hóa đơn</span>
                    <strong>@Model.TotalAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Đã thanh toán</span>
                    <strong>@Model.PaidAmount.ToString("N0") VND</strong>
                </div>

                <div class="booking-cost-row">
                    <span>Còn lại</span>
                    <strong class="text-danger">@Model.RemainingAmount.ToString("N0") VND</strong>
                </div>

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <a asp-controller="Receptionist"
                       asp-action="Invoices"
                       class="btn btn-outline-secondary">
                        Quay lại
                    </a>

                    @if (Model.CanRecordPayment)
                    {
                        <a asp-controller="Receptionist"
                           asp-action="RecordPayment"
                           asp-route-invoiceId="@Model.InvoiceId"
                           class="btn btn-success">
                            Ghi nhận thanh toán
                        </a>
                    }
                    else
                    {
                        <button type="button"
                                class="btn btn-outline-secondary"
                                disabled
                                title="@Model.RecordPaymentBlockReason">
                            Không thể thanh toán
                        </button>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Dịch vụ phát sinh</h5>

                @if (Model.Services == null || !Model.Services.Any())
                {
                    <div class="alert alert-info mb-0">
                        Booking này không có dịch vụ phát sinh.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 receptionist-invoice-lines-table">
                            <thead>
                                <tr>
                                    <th>Dịch vụ</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var item in Model.Services)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@item.ServiceName</div>
                                            <div class="text-muted small">@(item.Category ?? "Chưa phân loại")</div>

                                            @if (!string.IsNullOrWhiteSpace(item.Note))
                                            {
                                                <div class="text-muted small">Ghi chú: @item.Note</div>
                                            }
                                        </td>

                                        <td>@item.Quantity @(item.Unit ?? "")</td>
                                        <td>@item.UnitPrice.ToString("N0") VND</td>
                                        <td><strong>@item.TotalPrice.ToString("N0") VND</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h5 class="fw-bold mb-3">Thanh toán</h5>

                @if (Model.Payments == null || !Model.Payments.Any())
                {
                    <div class="alert alert-info mb-0">
                        Hóa đơn này chưa có giao dịch thanh toán.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 receptionist-invoice-lines-table">
                            <thead>
                                <tr>
                                    <th>Mã thanh toán</th>
                                    <th>Phương thức</th>
                                    <th>Số tiền</th>
                                    <th>Trạng thái</th>
                                    <th>Thời gian</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var payment in Model.Payments)
                                {
                                    <tr>
                                        <td>@payment.PaymentCode</td>
                                        <td>
                                            @(payment.PaymentMethod == "Cash" ? "Tiền mặt" : payment.PaymentMethod == "BankTransfer" ? "Chuyển khoản" : payment.PaymentMethod)
                                        </td>
                                        <td><strong>@payment.Amount.ToString("N0") VND</strong></td>
                                        <td>@payment.Status</td>
                                        <td>@(payment.PaidAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
