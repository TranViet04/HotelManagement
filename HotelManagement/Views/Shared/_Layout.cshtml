@{
    var isAuthenticated = User.Identity != null && User.Identity.IsAuthenticated;
    var isCustomer = User.IsInRole("Customer");
    var usesSidebar = isAuthenticated && !isCustomer;
    var controllerName = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var actionName = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    var liveSyncActions = new Dictionary<string, HashSet<string>>(StringComparer.OrdinalIgnoreCase)
    {
        ["Admin"] = new(StringComparer.OrdinalIgnoreCase)
        {
            "Dashboard", "RoomTypes", "Rooms", "RoomDetails", "Services",
            "Employees", "Customers", "CustomerDetails", "Bookings", "BookingDetails",
            "Invoices", "InvoiceDetails", "RevenueReport", "ActivityLogs"
        },
        ["Receptionist"] = new(StringComparer.OrdinalIgnoreCase)
        {
            "Dashboard", "Bookings", "BookingDetails", "TodayCheckIns", "TodayCheckOuts",
            "RoomStatus", "BookingServices", "Invoices", "InvoiceDetails", "Payments"
        }
    };

    var enableManagementLiveSync = usesSidebar
        && liveSyncActions.TryGetValue(controllerName, out var allowedActions)
        && allowedActions.Contains(actionName);

    var roleTitle = "Khách";
    var roleBadgeClass = "bg-secondary";

    if (User.IsInRole("Admin"))
    {
        roleTitle = "Quản trị viên";
        roleBadgeClass = "bg-danger";
    }
    else if (User.IsInRole("Receptionist"))
    {
        roleTitle = "Lễ tân";
        roleBadgeClass = "bg-primary";
    }
    else if (User.IsInRole("Customer"))
    {
        roleTitle = "Khách hàng";
        roleBadgeClass = "bg-success";
    }
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HotelManagement</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/home-official.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/management-live-sync.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chat-widget.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HotelManagement.styles.css" asp-append-version="true" />
</head>

<body>
    <header class="app-topbar">
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">
                @if (usesSidebar)
                {
                    <button class="btn btn-outline-secondary d-lg-none me-2"
                            type="button"
                            data-bs-toggle="offcanvas"
                            data-bs-target="#mobileSidebar"
                            aria-controls="mobileSidebar">
                        Menu
                    </button>
                }

                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    HotelManagement
                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#topNavbar"
                        aria-controls="topNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="topNavbar">
                    <ul class="navbar-nav public-primary-nav me-auto mb-2 mb-lg-0">
                        @if (!isAuthenticated || isCustomer)
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Rooms" asp-action="Index">
                                    Lưu trú
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/#services">
                                    Dịch vụ
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/#offers">
                                    Ưu đãi
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/#about">
                                    Giới thiệu
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" href="/#contact">
                                    Liên hệ
                                </a>
                            </li>

                            <li class="nav-item d-flex align-items-center ms-lg-2">
                                <a class="btn btn-primary btn-sm px-3" href="/#booking">
                                    Đặt phòng
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (isAuthenticated)
                        {
                            @if (isCustomer)
                            {
                                <li class="nav-item">
                                    <a class="nav-link customer-header-bookings"
                                       asp-controller="Bookings"
                                       asp-action="MyBookings">
                                        Lịch sử đặt phòng
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link customer-profile-link"
                                       asp-controller="Customer"
                                       asp-action="Profile"
                                       title="Xem thông tin cá nhân">
                                        @User.Identity!.Name
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-link nav-link text-dark">
                                            Đăng xuất
                                        </button>
                                    </form>
                                </li>
                            }
                            else
                            {
                            @if (User.IsInRole("Receptionist"))
                            {
                                <li class="nav-item d-flex align-items-center me-2">
                                    <a asp-controller="ReceptionistChat"
                                       asp-action="Index"
                                       class="nav-link d-inline-flex align-items-center gap-2">
                                        Tin nhắn
                                        <span class="badge rounded-pill bg-danger"
                                              data-receptionist-chat-count
                                              aria-label="Tin nhắn khách hàng chưa đọc"
                                              hidden></span>
                                    </a>
                                </li>
                            }

                            <li class="nav-item d-flex align-items-center me-2">
                                <span class="badge @roleBadgeClass">
                                    @roleTitle
                                </span>
                            </li>

                            <li class="nav-item">
                                <span class="nav-link text-dark">
                                    Xin chào, @User.Identity!.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-link nav-link text-dark">
                                        Đăng xuất
                                    </button>
                                </form>
                            </li>
                            }
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Auth" asp-action="Login">
                                    Đăng nhập
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="btn btn-primary ms-lg-2" asp-controller="Auth" asp-action="Register">
                                    Đăng ký
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @if (usesSidebar)
    {
        <div class="offcanvas offcanvas-start app-mobile-sidebar"
             tabindex="-1"
             id="mobileSidebar"
             aria-labelledby="mobileSidebarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="mobileSidebarLabel">
                    @roleTitle
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="offcanvas"
                        aria-label="Close">
                </button>
            </div>

            <div class="offcanvas-body p-0">
                @if (User.IsInRole("Admin"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_AdminMenu.cshtml")
                }
                else if (User.IsInRole("Receptionist"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_ReceptionistMenu.cshtml")
                }
                else if (User.IsInRole("Customer"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_CustomerMenu.cshtml")
                }
            </div>
        </div>
    }

    <div class="app-shell">
        @if (usesSidebar)
        {
            <aside class="app-sidebar d-none d-lg-block">
                <div class="sidebar-header">
                    <div class="sidebar-role">@roleTitle</div>
                    <div class="sidebar-user">@User.Identity!.Name</div>
                </div>

                @if (User.IsInRole("Admin"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_AdminMenu.cshtml")
                }
                else if (User.IsInRole("Receptionist"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_ReceptionistMenu.cshtml")
                }
                else if (User.IsInRole("Customer"))
                {
                    @await Html.PartialAsync("~/Views/Shared/RoleMenus/_CustomerMenu.cshtml")
                }
            </aside>
        }

        <main class="app-main @(usesSidebar ? "" : "app-main-public")">
            <div class="container-fluid py-4">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (enableManagementLiveSync)
                {
                    <div class="management-live-sync-bar" data-management-live-status role="status" aria-live="polite">
                        <span class="management-live-sync-dot" aria-hidden="true"></span>
                        <span data-management-live-label>Tự động đồng bộ mỗi 5 giây</span>
                        <button type="button"
                                class="btn btn-sm btn-link p-0"
                                data-management-live-refresh>
                            Cập nhật ngay
                        </button>
                    </div>

                    <div data-management-live-region data-management-live-interval="5000">
                        @RenderBody()
                    </div>
                }
                else
                {
                    @RenderBody()
                }
            </div>

            <footer class="app-footer border-top">
                <div class="container-fluid">
                    @if (usesSidebar)
                    {
                        <div class="text-muted">
                            &copy; 2026 - HotelManagement
                        </div>
                    }
                    else
                    {
                        <div class="public-footer-grid">
                            <div>
                                <div class="public-footer-brand">HotelManagement</div>
                                <p class="mb-0">
                                    Khách sạn boutique với đặt phòng trực tuyến, thông tin phòng rõ ràng và hỗ trợ lễ tân nhanh chóng.
                                </p>
                            </div>

                            <div>
                                <div class="public-footer-title">Điều hướng</div>
                                <a asp-controller="Rooms" asp-action="Index">Lưu trú</a>
                                <a href="/#services">Dịch vụ</a>
                                <a href="/#offers">Ưu đãi</a>
                                <a href="/#about">Giới thiệu</a>
                                <a href="/#contact">Liên hệ</a>
                            </div>

                            <div>
                                <div class="public-footer-title">Liên hệ</div>
                                <span>0123 456 789</span>
                                <span>support@hotelmanagement.local</span>
                                <span>Quận 1, TP. Hồ Chí Minh</span>
                            </div>

                            <div>
                                <div class="public-footer-title">Kết nối</div>
                                <div class="public-footer-socials">
                                    <a href="#" aria-label="Facebook">Fb</a>
                                    <a href="#" aria-label="Instagram">Ig</a>
                                    <a href="#" aria-label="YouTube">Yt</a>
                                </div>
                            </div>
                        </div>

                        <div class="public-footer-bottom">
                            &copy; 2026 - HotelManagement
                        </div>
                    }
                </div>
            </footer>
        </main>
    </div>

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
    {
        @await Html.PartialAsync("~/Views/Shared/Chat/_CustomerChatWidget.cshtml")
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (enableManagementLiveSync)
    {
        <script src="~/js/management-live-sync.js" asp-append-version="true"></script>
    }

    @if (User.Identity?.IsAuthenticated == true
        && (User.IsInRole("Customer") || User.IsInRole("Receptionist")))
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
        <script src="~/js/chat-notifications.js" asp-append-version="true"></script>
    }

    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
    {
        <script src="~/js/customer-chat-widget.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
