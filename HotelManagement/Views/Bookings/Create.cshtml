@model HotelManagement.ViewModels.Customer.CreateBookingViewModel

@{
    ViewData["Title"] = "Đặt phòng";
}

<section class="booking-create-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Đặt phòng online
            </div>

            <h1 class="fw-bold mb-3">
                Xác nhận thông tin đặt phòng
            </h1>

            <p class="text-muted mb-0">
                Kiểm tra lại thông tin phòng, thời gian lưu trú và số lượng khách trước khi gửi yêu cầu đặt phòng.
            </p>
        </div>

        <div class="col-lg-4 text-lg-end">
            <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-primary">
                Tìm phòng khác
            </a>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            @if (!string.IsNullOrWhiteSpace(Model.ThumbnailUrl))
            {
                <img src="@Model.ThumbnailUrl"
                     class="card-img-top booking-room-img"
                     alt="@Model.RoomTypeName" />
            }
            else
            {
                <div class="booking-room-img booking-room-placeholder d-flex align-items-center justify-content-center">
                    <span>@Model.RoomTypeName</span>
                </div>
            }

            <div class="card-body">
                <h4 class="fw-bold mb-2">@Model.RoomTypeName</h4>

                <div class="text-muted mb-3">
                    Phòng @Model.RoomNumber
                    @if (Model.Floor.HasValue)
                    {
                        <span> - Tầng @Model.Floor</span>
                    }
                </div>

                <p class="text-muted">
                    @if (!string.IsNullOrWhiteSpace(Model.Description))
                    {
                        @Model.Description
                    }
                    else
                    {
                        <span>Chưa có mô tả cho loại phòng này.</span>
                    }
                </p>

                <div class="room-info-list mb-3">
                    <div>
                        <span class="text-muted">Giá mỗi đêm:</span>
                        <strong>@Model.PricePerNight.ToString("N0") VND</strong>
                    </div>

                    <div>
                        <span class="text-muted">Sức chứa:</span>
                        <strong>@Model.Capacity khách</strong>
                    </div>

                    <div>
                        <span class="text-muted">Loại giường:</span>
                        <strong>@(Model.BedType ?? "Đang cập nhật")</strong>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(Model.AvailabilityMessage))
                {
                    <div class="alert @(Model.IsAvailableForSelectedDates ? "alert-success" : "alert-warning") mb-0">
                        @Model.AvailabilityMessage
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form asp-controller="Bookings" asp-action="Create" method="post">
                    @Html.AntiForgeryToken()

                    <input asp-for="RoomId" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CheckInDate" class="form-label">Ngày nhận phòng</label>
                            <input asp-for="CheckInDate"
                                   type="date"
                                   class="form-control" />
                            <span asp-validation-for="CheckInDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CheckOutDate" class="form-label">Ngày trả phòng</label>
                            <input asp-for="CheckOutDate"
                                   type="date"
                                   class="form-control" />
                            <span asp-validation-for="CheckOutDate" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Adults" class="form-label">Người lớn</label>
                            <input asp-for="Adults"
                                   type="number"
                                   min="1"
                                   class="form-control" />
                            <span asp-validation-for="Adults" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Children" class="form-label">Trẻ em</label>
                            <input asp-for="Children"
                                   type="number"
                                   min="0"
                                   class="form-control" />
                            <span asp-validation-for="Children" class="text-danger"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="SpecialRequest" class="form-label">Yêu cầu đặc biệt</label>
                            <textarea asp-for="SpecialRequest"
                                      class="form-control"
                                      rows="4"
                                      placeholder="Ví dụ: cần phòng yên tĩnh, nhận phòng sớm, thêm gối..."></textarea>
                            <span asp-validation-for="SpecialRequest" class="text-danger"></span>
                        </div>
                    </div>

                    <hr class="my-4" />

                    <div class="booking-summary bg-light p-3 mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span>Số đêm</span>
                            <strong>@Model.Nights</strong>
                        </div>

                        <div class="d-flex justify-content-between mb-2">
                            <span>Giá mỗi đêm</span>
                            <strong>@Model.PricePerNight.ToString("N0") VND</strong>
                        </div>

                        <div class="d-flex justify-content-between fs-5">
                            <span>Tạm tính</span>
                            <strong class="text-primary">@Model.TotalRoomAmount.ToString("N0") VND</strong>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        Sau khi gửi yêu cầu, đặt phòng sẽ ở trạng thái <strong>Pending</strong> và chờ lễ tân xác nhận.
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg w-100">
                        Xác nhận đặt phòng
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
