@model HotelManagement.ViewModels.Customer.RoomListViewModel

@{
    ViewData["Title"] = "Danh sách phòng";
    var hasValidAvailabilitySearch = Model.HasAvailabilitySearch && ViewData.ModelState.IsValid;
}

<section class="room-list-header shadow-sm p-4 p-lg-5 mb-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Danh sách phòng
            </div>

            <h1 class="fw-bold mb-3">
                @(Model.HasAvailabilitySearch
                    ? "Loại phòng còn trống theo thời gian lưu trú"
                    : "Chọn loại phòng phù hợp với nhu cầu lưu trú")
            </h1>

            <p class="text-muted mb-0">
                @if (hasValidAvailabilitySearch)
                {
                    <span>
                        Đang hiển thị các loại phòng còn trống từ
                        <strong>@Model.CheckInDate.ToString("dd/MM/yyyy")</strong>
                        đến
                        <strong>@Model.CheckOutDate.ToString("dd/MM/yyyy")</strong>
                        cho @(Model.Adults + Model.Children) khách.
                    </span>
                }
                else
                {
                    <span>
                        Xem thông tin giá, sức chứa, loại giường và mô tả từng loại phòng trước khi tìm phòng trống.
                    </span>
                }
            </p>
        </div>

    </div>
</section>

@if (Model.HasAvailabilitySearch && !ViewData.ModelState.IsValid)
{
    <div class="alert alert-warning">
        Vui lòng kiểm tra lại ngày nhận phòng, ngày trả phòng và số lượng khách.
    </div>
}

@if (Model.Rooms == null || !Model.Rooms.Any())
{
    <div class="alert alert-info">
        @(hasValidAvailabilitySearch
            ? "Không tìm thấy loại phòng phù hợp trong khoảng thời gian đã chọn."
            : "Hiện chưa có loại phòng nào đang hoạt động.")
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var room in Model.Rooms)
        {
            <div class="col-md-6 col-xl-4">
                <div class="card room-card h-100 border-0 shadow-sm">
                    @if (!string.IsNullOrWhiteSpace(room.ThumbnailUrl))
                    {
                        <img src="@room.ThumbnailUrl"
                             class="card-img-top room-card-img"
                             alt="@room.Name" />
                    }
                    else
                    {
                        <div class="room-card-img room-card-placeholder d-flex align-items-center justify-content-center">
                            <span>@room.Name</span>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                            <h5 class="card-title fw-bold mb-0">
                                @room.Name
                            </h5>

                            <span class="badge bg-light text-dark">
                                @room.Capacity khách
                            </span>
                        </div>

                        <p class="card-text text-muted flex-grow-1">
                            @if (!string.IsNullOrWhiteSpace(room.Description))
                            {
                                @room.Description
                            }
                            else
                            {
                                <span>Chưa có mô tả cho loại phòng này.</span>
                            }
                        </p>

                        <div class="room-info-list mb-3">
                            <div>
                                <span class="text-muted">Loại giường:</span>
                                <strong>@(room.BedType ?? "Đang cập nhật")</strong>
                            </div>

                            <div>
                                <span class="text-muted">Phòng trống:</span>
                                <strong>@room.AvailableRoomCount</strong>
                            </div>
                        </div>

                        <div class="room-price mb-3">
                            <span class="text-muted">Từ</span>
                            <strong class="text-primary fs-5">
                                @room.Price.ToString("N0") VND
                            </strong>
                            <span class="text-muted">/ đêm</span>
                        </div>

                        <div class="d-grid gap-2">
                            <a asp-controller="Rooms"
                               asp-action="Details"
                               asp-route-id="@room.RoomTypeId"
                               asp-route-checkInDate="@(hasValidAvailabilitySearch ? Model.CheckInDate.ToString("yyyy-MM-dd") : null)"
                               asp-route-checkOutDate="@(hasValidAvailabilitySearch ? Model.CheckOutDate.ToString("yyyy-MM-dd") : null)"
                               asp-route-adults="@(hasValidAvailabilitySearch ? Model.Adults : null)"
                               asp-route-children="@(hasValidAvailabilitySearch ? Model.Children : null)"
                               class="btn @(hasValidAvailabilitySearch ? "btn-primary" : "btn-outline-primary")">
                                @(hasValidAvailabilitySearch ? "Xem phòng trống" : "Xem chi tiết")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
