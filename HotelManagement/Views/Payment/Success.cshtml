@{
    ViewData["Title"] = "Thanh toán thành công";
    var bookingId = ViewBag.BookingId;
}

<section class="booking-create-header shadow-sm p-4 p-lg-5 mb-4 text-center">
    <div class="mb-3">
        <span class="display-1 text-success">✓</span>
    </div>
    <h1 class="fw-bold mb-3">Thanh toán thành công!</h1>
    <p class="text-muted mb-0">
        Cảm ơn bạn đã thanh toán. Biên lai đã được gửi tới email Gmail của bạn.
    </p>
</section>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <p class="mb-4">
                    Đặt phòng của bạn đã được xác nhận. Vui lòng kiểm tra hộp thư Gmail (kể cả thư mục Spam).
                </p>

                <div class="d-flex flex-wrap gap-2 justify-content-center">
                    @if (bookingId != null)
                    {
                        <a asp-controller="Bookings"
                           asp-action="Details"
                           asp-route-id="@bookingId"
                           class="btn btn-primary">
                            Xem chi tiết đặt phòng
                        </a>
                    }

                    <a asp-controller="Bookings"
                       asp-action="MyBookings"
                       class="btn btn-outline-secondary">
                        Danh sách đặt phòng
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
