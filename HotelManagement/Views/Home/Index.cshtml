@model HotelManagement.ViewModels.Customer.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<section class="customer-hero boutique-hero p-4 p-lg-5 mb-4 shadow-sm">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                Boutique hotel
            </div>

            <h1 class="display-4 fw-bold mb-3">
                Nghỉ dưỡng tinh tế, đặt phòng nhanh chóng
            </h1>

            <p class="lead text-muted mb-4">
                Khám phá phòng nghỉ phù hợp, xem hình ảnh chi tiết và đặt phòng trực tuyến chỉ trong vài bước.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary btn-lg">
                    Xem phòng trống
                </a>

                <a href="#services" class="btn btn-outline-dark btn-lg">
                    Khám phá dịch vụ
                </a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="booking-search-card boutique-search-card bg-light p-4">
                <h5 class="fw-bold mb-3">Tìm phòng nhanh</h5>

                <form asp-controller="Rooms" asp-action="Index" method="get">
                    <div class="mb-3">
                        <label class="form-label">Ngày nhận phòng</label>
                        <input type="date"
                               name="CheckInDate"
                               class="form-control"
                               value="@Model.CheckInDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ngày trả phòng</label>
                        <input type="date"
                               name="CheckOutDate"
                               class="form-control"
                               value="@Model.CheckOutDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Người lớn</label>
                            <input type="number"
                                   name="Adults"
                                   class="form-control"
                                   value="@Model.Adults"
                                   min="1" />
                        </div>

                        <div class="col-6 mb-3">
                            <label class="form-label">Trẻ em</label>
                            <input type="number"
                                   name="Children"
                                   class="form-control"
                                   value="@Model.Children"
                                   min="0" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Kiểm tra phòng trống
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@await Component.InvokeAsync("RoomTypeCarousel")

<section class="mb-5">
    <div class="boutique-section-heading">
        <div>
            <div class="text-uppercase text-primary fw-semibold mb-2">Lưu trú</div>
            <h2 class="h3 fw-bold mb-1">Loại phòng nổi bật</h2>
            <p class="text-muted mb-0">
                Những lựa chọn được chuẩn bị cho kỳ nghỉ, chuyến công tác hoặc dịp đặc biệt của bạn.
            </p>
        </div>

        <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-secondary d-none d-md-inline-block">
            Xem tất cả
        </a>
    </div>

    @if (Model.FeaturedRooms == null || !Model.FeaturedRooms.Any())
    {
        <div class="alert alert-info">
            Hiện chưa có loại phòng nào để hiển thị.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var room in Model.FeaturedRooms)
            {
                <div class="col-md-6 col-xl-3">
                    <div class="card room-card boutique-room-card h-100 border-0 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(room.ThumbnailUrl))
                        {
                            <img src="@room.ThumbnailUrl"
                                 class="card-img-top room-card-img"
                                 alt="@room.Name" />
                        }
                        else
                        {
                            <div class="room-card-img room-card-placeholder d-flex align-items-center justify-content-center">
                                <span>@room.Name</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@room.Name</h5>

                            <p class="card-text text-muted small flex-grow-1">
                                @if (!string.IsNullOrWhiteSpace(room.Description))
                                {
                                    @room.Description
                                }
                                else
                                {
                                    <span>Không gian lưu trú tiện nghi, phù hợp cho nhiều nhu cầu.</span>
                                }
                            </p>

                            <div class="boutique-room-meta mb-3">
                                <span>@room.Capacity khách</span>
                                <span>@(room.BedType ?? "Đang cập nhật")</span>
                                <span>@room.AvailableRoomCount phòng trống</span>
                            </div>

                            <div class="fw-bold text-primary mb-3">
                                @room.Price.ToString("N0") VND / đêm
                            </div>

                            <a asp-controller="Rooms"
                               asp-action="Details"
                               asp-route-id="@room.RoomTypeId"
                               class="btn btn-outline-primary w-100">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<section id="services" class="boutique-services mb-5">
    <div class="boutique-section-heading">
        <div>
            <div class="text-uppercase text-primary fw-semibold mb-2">Dịch vụ</div>
            <h2 class="h3 fw-bold mb-1">Trải nghiệm nổi bật</h2>
            <p class="text-muted mb-0">
                Các tiện ích giúp kỳ lưu trú trở nên thoải mái, riêng tư và trọn vẹn hơn.
            </p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-xl-3">
            <div class="boutique-service-card">
                <div class="service-number">01</div>
                <h5>Nhà hàng</h5>
                <p>Thực đơn linh hoạt cho bữa sáng, bữa tối và những buổi gặp gỡ thân mật.</p>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="boutique-service-card">
                <div class="service-number">02</div>
                <h5>Spa thư giãn</h5>
                <p>Không gian chăm sóc sức khỏe nhẹ nhàng sau hành trình dài.</p>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="boutique-service-card">
                <div class="service-number">03</div>
                <h5>Giặt ủi</h5>
                <p>Dịch vụ tiện lợi cho khách lưu trú dài ngày hoặc đi công tác.</p>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="boutique-service-card">
                <div class="service-number">04</div>
                <h5>Đưa đón</h5>
                <p>Hỗ trợ di chuyển nhanh gọn từ sân bay, nhà ga hoặc các điểm trung tâm.</p>
            </div>
        </div>
    </div>
</section>

<section id="about" class="boutique-about mb-5">
    <div class="row align-items-center g-4">
        <div class="col-lg-5">
            <div class="boutique-about-image"></div>
        </div>

        <div class="col-lg-7">
            <div class="text-uppercase text-primary fw-semibold mb-2">Giới thiệu</div>
            <h2 class="fw-bold mb-3">Một điểm dừng chân ấm áp giữa nhịp sống thành phố</h2>
            <p class="text-muted">
                HotelManagement được định hướng như một khách sạn boutique nhỏ gọn: hình ảnh rõ ràng,
                thông tin phòng minh bạch, thao tác đặt phòng nhanh và đội ngũ lễ tân luôn sẵn sàng hỗ trợ qua chat realtime.
            </p>

            <div class="boutique-stats">
                <div>
                    <strong>24/7</strong>
                    <span>Hỗ trợ lễ tân</span>
                </div>
                <div>
                    <strong>Online</strong>
                    <span>Đặt phòng nhanh</span>
                </div>
                <div>
                    <strong>Rõ ràng</strong>
                    <span>Giá và phòng trống</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="boutique-gallery mb-5">
    <div class="boutique-section-heading">
        <div>
            <div class="text-uppercase text-primary fw-semibold mb-2">Gallery</div>
            <h2 class="h3 fw-bold mb-1">Không gian khách sạn</h2>
        </div>
    </div>

    <div class="boutique-gallery-grid">
        <div class="gallery-tile gallery-large"></div>
        <div class="gallery-tile gallery-restaurant"></div>
        <div class="gallery-tile gallery-room"></div>
    </div>
</section>

<section class="boutique-cta mb-4">
    <div>
        <div class="text-uppercase fw-semibold mb-2">Sẵn sàng cho kỳ lưu trú tiếp theo?</div>
        <h2 class="fw-bold mb-0">Kiểm tra phòng trống và đặt phòng ngay hôm nay.</h2>
    </div>

    <a asp-controller="Rooms" asp-action="Index" class="btn btn-light btn-lg">
        Xem phòng
    </a>
</section>
