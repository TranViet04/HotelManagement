@model HotelManagement.ViewModels.Customer.HomeViewModel

@{
    ViewData["Title"] = "Trang chủ";
}

<section class="customer-hero p-4 p-lg-5 mb-4 shadow-sm">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="text-uppercase text-primary fw-semibold mb-2">
                HotelManagement
            </div>

            <h1 class="display-5 fw-bold mb-3">
                Đặt phòng khách sạn nhanh chóng, thuận tiện
            </h1>

            <p class="lead text-muted mb-4">
                Tìm phòng phù hợp, xem thông tin chi tiết và đặt phòng trực tuyến chỉ trong vài bước.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <a asp-controller="Rooms" asp-action="Index" class="btn btn-primary btn-lg">
                    Xem danh sách phòng
                </a>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="booking-search-card bg-light p-4">
                <h5 class="fw-bold mb-3">Tìm phòng nhanh</h5>

                <form asp-controller="Rooms" asp-action="Index" method="get">
                    <div class="mb-3">
                        <label class="form-label">Ngày nhận phòng</label>
                        <input type="date"
                               name="CheckInDate"
                               class="form-control"
                               value="@Model.CheckInDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Ngày trả phòng</label>
                        <input type="date"
                               name="CheckOutDate"
                               class="form-control"
                               value="@Model.CheckOutDate.ToString("yyyy-MM-dd")" />
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label">Người lớn</label>
                            <input type="number"
                                   name="Adults"
                                   class="form-control"
                                   value="@Model.Adults"
                                   min="1" />
                        </div>

                        <div class="col-6 mb-3">
                            <label class="form-label">Trẻ em</label>
                            <input type="number"
                                   name="Children"
                                   class="form-control"
                                   value="@Model.Children"
                                   min="0" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Kiểm tra phòng trống
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

@await Component.InvokeAsync("RoomTypeCarousel")

<section class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="h3 fw-bold mb-1">Loại phòng nổi bật</h2>
            <p class="text-muted mb-0">
                Một số lựa chọn phù hợp cho khách lưu trú.
            </p>
        </div>

        <a asp-controller="Rooms" asp-action="Index" class="btn btn-outline-secondary d-none d-md-inline-block">
            Xem tất cả
        </a>
    </div>

    @if (Model.FeaturedRooms == null || !Model.FeaturedRooms.Any())
    {
        <div class="alert alert-info">
            Hiện chưa có loại phòng nào để hiển thị.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var room in Model.FeaturedRooms)
            {
                <div class="col-md-6 col-xl-3">
                    <div class="card room-card h-100 border-0 shadow-sm">
                        @if (!string.IsNullOrWhiteSpace(room.ThumbnailUrl))
                        {
                            <img src="@room.ThumbnailUrl"
                                 class="card-img-top room-card-img"
                                 alt="@room.Name" />
                        }
                        else
                        {
                            <div class="room-card-img room-card-placeholder d-flex align-items-center justify-content-center">
                                <span>@room.Name</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">@room.Name</h5>

                            <p class="card-text text-muted small flex-grow-1">
                                @if (!string.IsNullOrWhiteSpace(room.Description))
                                {
                                    @room.Description
                                }
                                else
                                {
                                    <span>Chưa có mô tả.</span>
                                }
                            </p>

                            <div class="mb-2 small">
                                <div>
                                    <strong>Sức chứa:</strong> @room.Capacity khách
                                </div>

                                <div>
                                    <strong>Giường:</strong> @(room.BedType ?? "Đang cập nhật")
                                </div>

                                <div>
                                    <strong>Phòng trống:</strong> @room.AvailableRoomCount
                                </div>
                            </div>

                            <div class="fw-bold text-primary mb-3">
                                @room.Price.ToString("N0") VND / đêm
                            </div>

                            <a asp-controller="Rooms"
                               asp-action="Details"
                               asp-route-id="@room.RoomTypeId"
                               class="btn btn-outline-primary w-100">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</section>

<section class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card card-dashboard h-100">
            <div class="card-body">
                <h5 class="fw-bold">Đặt phòng dễ dàng</h5>
                <p class="text-muted mb-0">
                    Khách hàng có thể tìm phòng và gửi yêu cầu đặt phòng trực tuyến.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-dashboard h-100">
            <div class="card-body">
                <h5 class="fw-bold">Thông tin rõ ràng</h5>
                <p class="text-muted mb-0">
                    Hiển thị giá, sức chứa, loại giường và mô tả phòng trước khi đặt.
                </p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-dashboard h-100">
            <div class="card-body">
                <h5 class="fw-bold">Theo dõi lịch sử</h5>
                <p class="text-muted mb-0">
                    Sau khi đăng nhập, khách hàng có thể xem lại các đặt phòng của mình.
                </p>
            </div>
        </div>
    </div>
</section>
